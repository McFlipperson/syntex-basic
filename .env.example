# === OpenRouter ===
OPENROUTER_API_KEY=           # master key — used as fallback for users without a personal key
OPENROUTER_MANAGEMENT_KEY=    # management key — used to create/update per-user keys

# === Neon Postgres ===
DATABASE_URL=

# === Cloudflare (for per-user tunnel provisioning) ===
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_TUNNEL_ROOT_DOMAIN=syntexprotocol.com

# === Auth ===
SESSION_SECRET=
# 32-byte hex; used to sign user session cookies

# === Public origin the widget is served from ===
PUBLIC_SITE_ORIGIN=https://syntexprotocol.com
PUBLIC_API_ORIGIN=https://api.syntexprotocol.com

# === Stripe ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=   # from Stripe Dashboard → Webhooks → endpoint secret (whsec_...)
